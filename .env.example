# PAK environment-variable template.
# Keep real keys in .env (gitignored).
#
# PAK runs all inference through an OpenAI-compatible / Ollama HTTP interface.
# The released PAK narratives were generated locally with qwen3:30b-a3b on Ollama.

# ----- Inference backend (choose one) -----

# Option A: local Ollama (default; the generator used for the release)
PAK_LLM_BACKEND=ollama_native
PAK_LLM_BASE_URL=http://localhost:11434
PAK_LLM_API_KEY=ollama
PAK_LLM_DEFAULT_MODEL=qwen3:30b-a3b
PAK_LLM_JUDGE_MODEL=qwen3:30b-a3b

# Option B: local vLLM (any OpenAI-compatible server)
# PAK_LLM_BACKEND=openai_compatible
# PAK_LLM_BASE_URL=http://localhost:8000/v1
# PAK_LLM_API_KEY=EMPTY
# PAK_LLM_DEFAULT_MODEL=<your-model>

# Option C: NVIDIA NIM
# PAK_LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# PAK_LLM_API_KEY=$NVIDIA_API_KEY
NVIDIA_API_KEY=

# Option D: OpenRouter
# PAK_LLM_BASE_URL=https://openrouter.ai/api/v1
# PAK_LLM_API_KEY=$OPENROUTER_API_KEY
OPENROUTER_API_KEY=

# Option E: Anthropic Claude (paid; optional, used only as a cross-family panel judge)
ANTHROPIC_API_KEY=

# ----- Publishing -----
HF_TOKEN=
ZENODO_TOKEN=

# ----- Cost guardrail -----
# 0 allows only self-host / free backends; a positive value also allows paid APIs.
PAK_LLM_BUDGET_USD=0
PAK_PDF_DPI=300
PAK_LLM_MAX_CONCURRENT=8
