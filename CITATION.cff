    given-names: Joonhyung
    orcid: "https://orcid.org/0000-0001-5933-4302"
    affiliation: "Korea Advanced Institute of Science and Technology (KAIST)"
year: 2026
license: CC-BY-4.0
repository-code: "https://github.com/joonhyungbae/pak"
url: "https://huggingface.co/datasets/joonhyungbae/Persona-Arts-Korea"
